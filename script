-- =====================================================================
-- 0. BASE DE DATOS
-- =====================================================================
CREATE DATABASE bd_ramon_vega_cumbia
    CHARACTER SET utf8mb4
    COLLATE utf8mb4_unicode_ci;

USE bd_ramon_vega_cumbia;

-- =====================================================================
-- 1. DDL - CREACION DE TABLAS (Modelo normalizado hasta 3FN)
-- =====================================================================

-- Ciudades
CREATE TABLE riwi_cities (
    id      INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    name    VARCHAR(100) NOT NULL,
    CONSTRAINT uq_cities_name UNIQUE (name)
) ENGINE=InnoDB;

-- Sedes (branches), cada sede pertenece a una ciudad
CREATE TABLE riwi_branches (
    id          INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    name        VARCHAR(100) NOT NULL,
    city_id     INT UNSIGNED NOT NULL,
    CONSTRAINT fk_branches_city FOREIGN KEY (city_id)
        REFERENCES riwi_cities (id)
        ON UPDATE CASCADE
        ON DELETE RESTRICT,
    CONSTRAINT uq_branches_name_city UNIQUE (name, city_id)
) ENGINE=InnoDB;

-- Clientes
CREATE TABLE riwi_clients (
    id      INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    name    VARCHAR(150) NOT NULL,
    CONSTRAINT uq_clients_name UNIQUE (name)
) ENGINE=InnoDB;

-- Tecnicos
CREATE TABLE riwi_technicians (
    id          INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    full_name   VARCHAR(150) NOT NULL,
    CONSTRAINT uq_technicians_name UNIQUE (full_name)
) ENGINE=InnoDB;

-- Categorias de equipo
CREATE TABLE riwi_equipment_categories (
    id      INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    name    VARCHAR(100) NOT NULL,
    CONSTRAINT uq_equipment_categories_name UNIQUE (name)
) ENGINE=InnoDB;

-- Equipos, cada equipo pertenece a una categoria
CREATE TABLE riwi_equipment (
    id              INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    name            VARCHAR(150) NOT NULL,
    category_id     INT UNSIGNED NOT NULL,
    CONSTRAINT fk_equipment_category FOREIGN KEY (category_id)
        REFERENCES riwi_equipment_categories (id)
        ON UPDATE CASCADE
        ON DELETE RESTRICT,
    CONSTRAINT uq_equipment_name_category UNIQUE (name, category_id)
) ENGINE=InnoDB;

-- Tipos de servicio
CREATE TABLE riwi_service_types (
    id      INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    name    VARCHAR(100) NOT NULL,
    CONSTRAINT uq_service_types_name UNIQUE (name)
) ENGINE=InnoDB;

-- Ordenes de servicio (tabla transaccional / hechos)
CREATE TABLE riwi_service_orders (
    id                  INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    order_number        VARCHAR(20) NOT NULL,
    client_id           INT UNSIGNED NOT NULL,
    branch_id           INT UNSIGNED NOT NULL,
    technician_id       INT UNSIGNED NOT NULL,
    equipment_id        INT UNSIGNED NOT NULL,
    service_type_id     INT UNSIGNED NOT NULL,
    service_date        DATE NOT NULL,
    hours               DECIMAL(5,2) NOT NULL,
    cost                DECIMAL(10,2) NOT NULL,
    CONSTRAINT uq_service_orders_number UNIQUE (order_number),
    CONSTRAINT fk_orders_client FOREIGN KEY (client_id)
        REFERENCES riwi_clients (id) ON UPDATE CASCADE ON DELETE RESTRICT,
    CONSTRAINT fk_orders_branch FOREIGN KEY (branch_id)
        REFERENCES riwi_branches (id) ON UPDATE CASCADE ON DELETE RESTRICT,
    CONSTRAINT fk_orders_technician FOREIGN KEY (technician_id)
        REFERENCES riwi_technicians (id) ON UPDATE CASCADE ON DELETE RESTRICT,
    CONSTRAINT fk_orders_equipment FOREIGN KEY (equipment_id)
        REFERENCES riwi_equipment (id) ON UPDATE CASCADE ON DELETE RESTRICT,
    CONSTRAINT fk_orders_service_type FOREIGN KEY (service_type_id)
        REFERENCES riwi_service_types (id) ON UPDATE CASCADE ON DELETE RESTRICT,
    CONSTRAINT chk_orders_hours CHECK (hours > 0),
    CONSTRAINT chk_orders_cost CHECK (cost >= 0)
) ENGINE=InnoDB;

