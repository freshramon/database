-- =====================================================================
-- 4. CONSULTAS SQL - NECESIDADES DEL NEGOCIO
-- =====================================================================

-- Consulta 1: Cantidad de ordenes atendidas por tecnico
SELECT
    riwi_technicians.id        		AS technician_id,
    riwi_technicians.full_name      AS technician,
    COUNT(riwi_service_orders.id) 	AS total_orders
FROM riwi_technicians
LEFT JOIN riwi_service_orders
    ON riwi_service_orders.technician_id = riwi_technicians.id
GROUP BY
    riwi_technicians.id,
    riwi_technicians.full_name
ORDER BY total_orders DESC;

-- Consulta 2: Historial de servicios realizados por ciudad
SELECT
    riwi_cities.id AS city_id,
    riwi_cities.name AS city,
    COUNT(riwi_service_orders.id) AS total_services
FROM riwi_cities
JOIN riwi_branches
    ON riwi_branches.city_id = riwi_cities.id
JOIN riwi_service_orders
    ON riwi_service_orders.branch_id = riwi_branches.id
GROUP BY
    riwi_cities.id,
    riwi_cities.name
ORDER BY total_services DESC;

-- Consulta 3: Total de servicios realizados por tipo de servicio
SELECT
    riwi_service_types.id AS service_type_id,
    riwi_service_types.name AS service_type,
    COUNT(riwi_service_orders.id) AS total_services
FROM riwi_service_types
LEFT JOIN riwi_service_orders
    ON riwi_service_orders.service_type_id = riwi_service_types.id
GROUP BY
    riwi_service_types.id,
    riwi_service_types.name
ORDER BY total_services DESC;

-- Consulta 4: Equipos con mayor cantidad de mantenimientos
SELECT
    riwi_equipment.id AS equipment_id,
    riwi_equipment.name AS equipment,
    COUNT(riwi_service_orders.id) AS total_maintenances
FROM riwi_equipment
JOIN riwi_service_orders
    ON riwi_service_orders.equipment_id = riwi_equipment.id
GROUP BY
    riwi_equipment.id,
    riwi_equipment.name
ORDER BY total_maintenances DESC;

-- Consulta 5: Clientes con mayor numero de ordenes de servicio
SELECT
    riwi_clients.id AS client_id,
    riwi_clients.name AS client,
    COUNT(riwi_service_orders.id) AS total_orders
FROM riwi_clients
JOIN riwi_service_orders
    ON riwi_service_orders.client_id = riwi_clients.id
GROUP BY
    riwi_clients.id,
    riwi_clients.name
ORDER BY total_orders DESC;

-- Consulta 6: Cantidad de ordenes gestionadas por sede
SELECT
    riwi_branches.id AS branch_id,
    riwi_branches.name AS branch,
    riwi_cities.name AS city,
    COUNT(riwi_service_orders.id) AS total_orders
FROM riwi_branches
JOIN riwi_cities
    ON riwi_cities.id = riwi_branches.city_id
LEFT JOIN riwi_service_orders
    ON riwi_service_orders.branch_id = riwi_branches.id
GROUP BY
    riwi_branches.id,
    riwi_branches.name,
    riwi_cities.name
ORDER BY total_orders DESC;
